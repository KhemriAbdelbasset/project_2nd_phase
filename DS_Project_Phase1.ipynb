   "source": [
    "### **Step 4: Tokenization & Encoding**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9ab111ae",
   "metadata": {},
   "source": [
    "Tokenization converts text into numerical representations that models can process. Using Hugging Face Transformers, we tokenize both the input text (articles) and target summaries.\n",
    "\n",
    "This step is essential for preparing the dataset for training transformer models like BART."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "e852bace",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "386c9dfb73ca4dbba8bd011bdfe60102",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "Map:   0%|          | 0/2000 [00:00<?, ? examples/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "from transformers import BartTokenizer\n",
    "\n",
    "# Load tokenizer\n",
    "tokenizer = BartTokenizer.from_pretrained(\"facebook/bart-large-cnn\")\n",
    "\n",
    "def tokenize_function(example):\n",
    "    # Tokenize input (article)\n",
    "    inputs = tokenizer(\n",
    "        example[\"article\"],\n",
    "        max_length=256,\n",
    "        truncation=True,\n",
    "        padding=\"max_length\"\n",
    "    )\n",
    "    \n",
    "    # Tokenize target (summary)\n",
    "    targets = tokenizer(\n",
    "        example[\"highlights\"],\n",
    "        max_length=64,\n",
    "        truncation=True,\n",
    "        padding=\"max_length\"\n",
    "    )\n",
    "    \n",
    "    inputs[\"labels\"] = targets[\"input_ids\"]\n",
    "    \n",
    "    return inputs\n",
    "\n",
    "# Apply tokenization\n",
    "tokenized_train = train_data.map(tokenize_function, batched=True)"
   ]
  },
